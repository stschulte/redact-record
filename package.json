{
  "name": "simple-redact",
  "version": "0.0.1",
  "description": "Redact or modify values of an object",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate": "tsc --noEmit",
    "all": "npm run validate && npm run lint && npm run build && npm run test:coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stschulte/simple-redact.git"
  },
  "author": "Stefan Schulte <stschulte@posteo.de>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/stschulte/simple-redact/issues"
  },
  "homepage": "https://github.com/stschulte/simple-redact#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint": "^10.4.0",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
